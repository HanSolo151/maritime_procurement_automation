    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  supplier_name,\n  location,\n  avg_price,\n  whatsapp,\n  email,\n  supported_materials,\n  supported_standards\nFROM suppliers\nWHERE \n  '{{ $json.material }}' = ANY(supported_materials)\n  AND '{{ $json.standard }}' = ANY(supported_standards)\nORDER BY avg_price ASC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [96, -176],
      "id": "eaa9688e-567b-4f47-bada-28c4477a5a0c",
      "name": "Execute a SQL query1",
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const requisition = $('Execute a SQL query').first().json;\nconst suppliers = $input.all();\n\nif (suppliers.length === 0) {\n  return [{ json: { error: 'No matching suppliers found', requisition } }];\n}\n\nconst totalPrice = suppliers.reduce((sum, s) => sum + parseFloat(s.json.avg_price), 0);\nconst benchmark = totalPrice / suppliers.length;\n\nconst ranked = suppliers.map(s => {\n  const price = parseFloat(s.json.avg_price);\n  const deviation = ((price - benchmark) / benchmark * 100).toFixed(2);\n  return {\n    supplier_name: s.json.supplier_name,\n    location: s.json.location,\n    avg_price: price,\n    deviation_percent: parseFloat(deviation),\n    whatsapp: s.json.whatsapp,\n    email: s.json.email,\n    flag: Math.abs(parseFloat(deviation)) > 15 ? '⚠️ HIGH' : '✅ OK'\n  };\n});\n\nconst best = ranked[0];\n\nreturn [{\n  json: {\n    requisition_id: requisition.id,\n    product_name: requisition.product_name,\n    material: requisition.material,\n    standard: requisition.standard,\n    benchmark_price: parseFloat(benchmark.toFixed(2)),\n    best_supplier: best.supplier_name,\n    best_price: best.avg_price,\n    best_deviation: best.deviation_percent,\n    best_whatsapp: best.whatsapp,\n    best_email: best.email,\n    all_suppliers: ranked,\n    alert_required: ranked.some(s => s.deviation_percent > 15)\n  }\n}];"
      },
